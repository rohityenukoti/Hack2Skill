# Firebase Web SDK (client-safe — no secret keys here)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: reCAPTCHA v3 site key for Firebase App Check (production)
VITE_RECAPTCHA_SITE_KEY=

# Google Maps JavaScript API (client-restricted key)
VITE_GOOGLE_MAPS_API_KEY=

# Set to "true" to use Firebase emulators locally
VITE_USE_FIREBASE_EMULATORS=false

